class Solution:
    def candy(self, ratings: list[int]) -> int:
        n = len(ratings)
        # 1. Every child gets at least one candy
        candies = [1] * n
        
        # 2. Left-to-Right Pass
        # Compare current child with the left neighbor
        for i in range(1, n):
            if ratings[i] > ratings[i - 1]:
                candies[i] = candies[i - 1] + 1
        
        # 3. Right-to-Left Pass
        # Compare current child with the right neighbor
        for i in range(n - 2, -1, -1):
            if ratings[i] > ratings[i + 1]:
                # We take the max to ensure we don't break 
                # the left-neighbor condition satisfied in the first pass
                candies[i] = max(candies[i], candies[i + 1] + 1)
                
        # 4. Return total candies
        return sum(candies)
