class Solution:
    def countDigitOne(self, n: int) -> int:
        if n <= 0:
            return 0
        
        count = 0
        i = 1  # Position multiplier (1 for units, 10 for tens, etc.)
        
        while i <= n:
            # Divide the number into three parts based on the current position i
            high = n // (i * 10)
            current = (n // i) % 10
            low = n % i
            
            # Case 1: Current digit is 0
            if current == 0:
                count += high * i
            # Case 2: Current digit is 1
            elif current == 1:
                count += high * i + (low + 1)
            # Case 3: Current digit is > 1
            else:
                count += (high + 1) * i
            
            # Move to the next power of 10
            i *= 10
            
        return count
