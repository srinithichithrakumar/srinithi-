import math

class Solution:
    def getPermutation(self, n: int, k: int) -> str:
        # 1. Create a list of numbers [1, 2, ..., n]
        numbers = [str(i) for i in range(1, n + 1)]
        
        # 2. Adjust k to be 0-indexed for easier math
        k -= 1
        
        result = []
        
        # 3. Precompute factorials or use math.factorial
        # We need (n-1)! to determine the first digit
        while n > 0:
            n -= 1
            # Number of permutations in each "block"
            fact = math.factorial(n)
            
            # Find the index of the current digit
            index = k // fact
            
            # Append the chosen number to our result and remove it from the list
            result.append(numbers.pop(index))
            
            # Update k to the remainder for the next iteration
            k %= fact
            
        return "".join(result)
