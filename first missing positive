class Solution:
    def firstMissingPositive(self, nums: list[int]) -> int:
        n = len(nums)
        
        for i in range(n):
            # While the current number is in range [1, n] 
            # and not in its correct position (nums[i]-1)
            while 1 <= nums[i] <= n and nums[nums[i] - 1] != nums[i]:
                # Swap nums[i] with the element at its target index
                target_idx = nums[i] - 1
                nums[i], nums[target_idx] = nums[target_idx], nums[i]
        
        # Second pass: find the first index where the value isn't i + 1
        for i in range(n):
            if nums[i] != i + 1:
                return i + 1
        
        # If all numbers 1 to n are present, return n + 1
        return n + 1
